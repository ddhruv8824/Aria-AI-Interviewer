# Copy to ai/.env (or project root .env) to override defaults in shared/config.py

# Interviewer display name (used in opening prompt)
INTERVIEWER_NAME=Aria

# Optional: override the full Gemini Live system prompt.
# If unset, the Aria persona default in shared/config.py is used.
# GEMINI_SYSTEM_PROMPT=You are Aria, a professional AI interviewer...

# Alias for GEMINI_SYSTEM_PROMPT (GEMINI_SYSTEM_PROMPT takes precedence)
# SYSTEM_PROMPT=

# Groq API key for post-interview judge (optional if set in config.py)
# GROQ_API_KEY=

# Gemini Live voice — female options: Sulafat (warm), Kore (firm), Aoede (breezy), Leda (youthful)
GEMINI_VOICE_NAME=Sulafat

# Speech language / accent (en-IN = Indian English, en-US = American English)
GEMINI_SPEECH_LANGUAGE_CODE=en-IN
